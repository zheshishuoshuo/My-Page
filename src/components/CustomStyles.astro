---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(37 99 235);
    --aw-color-secondary: rgb(14 165 233);
    --aw-color-accent: rgb(245 158 11);

    --aw-color-text-heading: rgb(15 23 42);
    --aw-color-text-default: rgb(30 41 59);
    --aw-color-text-muted: rgb(51 65 85 / 82%);
    --aw-color-bg-page: rgb(246 248 252);

    --aw-color-bg-page-dark: rgb(7 11 24);

    ::selection {
      background-color: rgb(191 219 254);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(96 165 250);
    --aw-color-secondary: rgb(56 189 248);
    --aw-color-accent: rgb(251 191 36);

    --aw-color-text-heading: rgb(241 245 249);
    --aw-color-text-default: rgb(226 232 240);
    --aw-color-text-muted: rgb(203 213 225 / 72%);
    --aw-color-bg-page: rgb(7 11 24);

    ::selection {
      background-color: rgb(30 41 59);
      color: rgb(248 250 252);
    }
  }
</style>
